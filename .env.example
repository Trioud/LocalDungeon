# LocalDungeon API — Environment Variables
# Copy to .env.development or .env.production and fill in real values.
# Never commit real secrets.

NODE_ENV=development
PORT=3001

# PostgreSQL (via Docker Compose)
DATABASE_URL=postgresql://localdungeon:localdungeon@localhost:5432/localdungeon_dev

# Redis (via Docker Compose)
REDIS_URL=redis://localhost:6379

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars_long

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000
