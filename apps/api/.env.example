# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://localdungeon:localdungeon@localhost:5432/localdungeon_dev"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters each
JWT_ACCESS_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
JWT_REFRESH_SECRET="change-me-to-another-long-random-secret-32-chars"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# ─── File Storage ─────────────────────────────────────────────────────────────
# Use "memory" locally (no S3 needed). Switch to "s3" for production.
STORAGE_PROVIDER=memory

# S3 / R2 — only needed when STORAGE_PROVIDER=s3
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com   # Cloudflare R2 only
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_PUBLIC_BASE_URL=https://cdn.yourdomain.com

# ─── Speech-to-Text ───────────────────────────────────────────────────────────
# Use "mock" locally (no API key needed). Switch to "deepgram" for production.
STT_PROVIDER=mock

# Deepgram — only needed when STT_PROVIDER=deepgram
# DEEPGRAM_API_KEY=your-deepgram-api-key
